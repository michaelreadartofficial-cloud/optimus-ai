# Copy this file to .env.local for local development and fill in real
# values. In production, set these as Vercel env vars (Project ->
# Settings -> Environment Variables).

# --- Supabase (auth + database) ---
# From your Supabase project's Settings -> API page.
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...your-anon-public-key...

# --- Existing backend keys (already in Vercel) ---
# OPENAI_API_KEY=sk-...           # Whisper transcription
# ANTHROPIC_API_KEY=sk-ant-...    # Claude script remix/generate
# RAPIDAPI_KEY=...                # Instagram scraper

